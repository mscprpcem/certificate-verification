{
  "name": "msc-credential-platform",
  "version": "1.0.0",
  "description": "Microsoft Student Club Credential Engine & Wallet Portal",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "node backend/server.js",
    "dev": "npm run build --prefix frontend && node backend/server.js",
    "build": "npm run build --prefix frontend",
    "postinstall": "prisma generate --schema=backend/prisma/schema.prisma",
    "lint": "npm run lint --prefix frontend"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.32.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "prisma": "^6.19.3",
    "sequelize": "^6.37.8",
    "sqlite3": "^5.1.7"
  }
}
