# PostgreSQL Database URL (Neon / Azure / Local)
DATABASE_URL=postgresql://neondb_owner:password@ep-xxxx.ap-south-1.aws.neon.tech/neondb?sslmode=require

# Azure Blob Storage Configuration (for SVG templates)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=certificate-templates

# Server Port (Azure App Service sets PORT automatically)
PORT=3000

# Node Environment
NODE_ENV=development

# Session Secret Key
SESSION_SECRET=msc-club-credentials-secret-key-2026

# Frontend Application Base URL (for QR code & Email verification links)
FRONTEND_URL=http://localhost:5173

# Initial Admin Account (used to seed the first admin on fresh databases)
INITIAL_ADMIN_EMAIL=admin@mscprpcem.tech
INITIAL_ADMIN_PASSWORD=admin123
INITIAL_ADMIN_NAME=MSC Club Admin
